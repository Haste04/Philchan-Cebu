---
/**
 * Layout.astro
 * Base document shell: <head> meta, SEO, OpenGraph, and global font preloading.
 * Includes Astro View Transitions for immersive SPA-like navigation,
 * and a global Intersection Observer for scroll animations.
 */
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  /** Path relative to /public, e.g. "/og-default.jpg" */
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage = "/og-default.jpg",
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'http://localhost');
const ogImageURL = new URL(ogImage, Astro.site || 'http://localhost');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <link rel="icon" type="image/jpeg" href="/PhilChan-Cebu Logo.jpg" />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="author"
      content="PhilCHAN Cebu - Philippine Catholic HIV/AIDS Network Inc."
    />

    <!-- Theme color -->
    <meta
      name="theme-color"
      content="#FCFBF9"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#FCFBF9"
      media="(prefers-color-scheme: dark)"
    />

    <!-- OpenGraph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="en_PH" />
    <meta property="og:site_name" content="PhilCHAN Cebu" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Font preloading -->
    <link
      rel="preload"
      href="/fonts/fraunces-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/public-sans-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Preconnect to Google Maps origin -->
    <link rel="preconnect" href="https://www.google.com" />

    <ClientRouter />

    <!-- Inline Script to set theme (if used) -->
    <script is:inline>
      (function () {
        const storedTheme = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;

        if (storedTheme === "dark" || (!storedTheme && prefersDark)) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
  </head>
  <body class="flex flex-col min-h-screen bg-health-white text-health-text transition-colors duration-300">
    <a href="#main" class="skip-link">Skip to main content</a>
    
    <div class="flex-grow">
      <slot />
    </div>

    <!-- Global Scroll Animation Script -->
    <script>
      function initScrollAnimations() {
        const reveals = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('active');
              // Optional: Stop observing once revealed
              // observer.unobserve(entry.target);
            }
          });
        }, {
          root: null,
          rootMargin: '0px 0px -10% 0px',
          threshold: 0.1
        });

        reveals.forEach(element => {
          observer.observe(element);
        });
      }

      // Run on initial load
      document.addEventListener('DOMContentLoaded', initScrollAnimations);
      
      // Run on ViewTransition swap
      document.addEventListener('astro:after-swap', initScrollAnimations);
    </script>
  </body>
</html>
