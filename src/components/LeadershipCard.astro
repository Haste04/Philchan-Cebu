---
/**
 * LeadershipCard.astro
 * Modern immersive side-by-side card layout.
 * Supports reversing the layout via `isReversed` prop.
 */
import {
  User,
  Award,
  Stethoscope,
  Church,
  Briefcase,
  GraduationCap,
} from "@lucide/astro";
import type { LeaderProfile } from "../data/landingData";

interface Props {
  profile: LeaderProfile;
  isReversed?: boolean;
}

const { profile, isReversed = false } = Astro.props;

const isMedical = profile.credentials?.some(
  (c) => c.toLowerCase().includes("md") || c.toLowerCase().includes("doctor")
);
const isClergy =
  profile.title?.toLowerCase().includes("rev") ||
  profile.title?.toLowerCase().includes("father");
---

<div class="w-full py-2 group">
  <div class="grid grid-cols-1 items-stretch gap-6 lg:grid-cols-12 w-full">
    <!-- Image / Avatar Container -->
    <div class={`lg:col-span-4 flex ${isReversed ? 'lg:order-last' : 'lg:order-first'}`}>
      <div
        class="relative w-full overflow-hidden rounded-[2.5rem] bg-health-white p-2 shadow-soft border border-health-border/30 flex items-center justify-center min-h-[350px] transition-all duration-500 group-hover:shadow-card group-hover:border-health-green/20"
      >
        {
          profile.imagePath ? (
            <img
              src={`/${profile.imagePath.replace(/^\//, "")}`}
              alt={`Photo of ${profile.name}`}
              class="h-full w-full rounded-[2rem] object-cover min-h-[330px] transition-transform duration-700 ease-out group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div class="flex h-full w-full min-h-[330px] flex-col items-center justify-center rounded-[2rem] bg-gradient-to-b from-health-bg to-health-white text-health-border/80 transition-transform duration-700 group-hover:scale-105">
              {isMedical ? (
                <Stethoscope class="h-20 w-20 text-health-green/40" />
              ) : isClergy ? (
                <Church class="h-20 w-20 text-health-green/40" />
              ) : (
                <User class="h-20 w-20 text-health-green/40" />
              )}
              <span class="mt-4 text-xs font-bold uppercase tracking-wider text-health-text/40">
                Photo Pending
              </span>
            </div>
          )
        }
      </div>
    </div>

    <!-- Profile Details & Mini-Badge Grid -->
    <div class={`lg:col-span-8 flex ${isReversed ? 'lg:order-first' : 'lg:order-last'}`}>
      <div
        class="flex w-full flex-col justify-between glass-card p-8 sm:p-12 transition-all duration-500 group-hover:-translate-y-1 group-hover:shadow-xl border-health-border/50"
      >
        <!-- Header & Bio -->
        <div>
          <span
            class="inline-block px-3 py-1 rounded-full bg-health-red/10 text-xs font-bold uppercase tracking-wider text-health-red"
          >
            {profile.title}
          </span>
          <h3
            class="mt-4 font-display text-3xl font-bold text-health-green sm:text-4xl"
          >
            {profile.name}
          </h3>

          {
            profile.bio && (
              <p class="mt-6 text-lg font-medium leading-relaxed text-health-text/70">
                {profile.bio}
              </p>
            )
          }
        </div>

        <!-- 2x2 Mini Highlight Grid -->
        <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2">
          <!-- Badge 1: Role -->
          <div
            class="flex items-center gap-5 rounded-3xl border border-health-border/30 bg-health-white/50 p-4 transition-colors group-hover:bg-health-white"
          >
            <div
              class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-health-green-pale text-health-green shadow-sm"
            >
              {
                isClergy ? (
                  <Church class="h-6 w-6" />
                ) : (
                  <Briefcase class="h-6 w-6" />
                )
              }
            </div>
            <div>
              <p
                class="text-[10px] font-bold uppercase tracking-wider text-health-text/50"
              >
                Role
              </p>
              <p
                class="text-sm font-bold text-health-text line-clamp-1"
              >
                {profile.title}
              </p>
            </div>
          </div>

          <!-- Badge 2: Field -->
          <div
            class="flex items-center gap-5 rounded-3xl border border-health-border/30 bg-health-white/50 p-4 transition-colors group-hover:bg-health-white"
          >
            <div
              class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-health-green-pale text-health-green shadow-sm"
            >
              {
                isMedical ? (
                  <Stethoscope class="h-6 w-6" />
                ) : (
                  <GraduationCap class="h-6 w-6" />
                )
              }
            </div>
            <div>
              <p
                class="text-[10px] font-bold uppercase tracking-wider text-health-text/50"
              >
                Field
              </p>
              <p class="text-sm font-bold text-health-text">
                {
                  isMedical
                    ? "Medical Ministry"
                    : isClergy
                      ? "Pastoral Ministry"
                      : "Community Leader"
                }
              </p>
            </div>
          </div>

          <!-- Badge 3 & 4: Credentials / Affiliation -->
          {
            profile.credentials && profile.credentials.length > 0 ? (
              profile.credentials.slice(0, 2).map((cred) => (
                <div class="flex items-center gap-5 rounded-3xl border border-health-border/30 bg-health-white/50 p-4 transition-colors group-hover:bg-health-white">
                  <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-health-green-pale text-health-green shadow-sm">
                    <Award class="h-6 w-6" />
                  </div>
                  <div>
                    <p class="text-[10px] font-bold uppercase tracking-wider text-health-text/50">
                      Qualification
                    </p>
                    <p class="text-sm font-bold text-health-text line-clamp-1">
                      {cred}
                    </p>
                  </div>
                </div>
              ))
            ) : (
              <div class="flex items-center gap-5 rounded-3xl border border-health-border/30 bg-health-white/50 p-4 transition-colors group-hover:bg-health-white">
                <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-health-green-pale text-health-green shadow-sm">
                  <Award class="h-6 w-6" />
                </div>
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-wider text-health-text/50">
                    Affiliation
                  </p>
                  <p class="text-sm font-bold text-health-text">
                    PhilCHAN Cebu
                  </p>
                </div>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>
</div>
