---
/**
 * LeadershipCard.astro
 * Side-by-side card layout: Portrait image/avatar on the left, profile info & mini badges on the right.
 */
import {
  User,
  Award,
  Stethoscope,
  Church,
  Briefcase,
  GraduationCap,
} from "@lucide/astro";
import type { LeaderProfile } from "../data/landingData";

interface Props {
  profile: LeaderProfile;
}

const { profile } = Astro.props;

const isMedical = profile.credentials?.some(
  (c) => c.toLowerCase().includes("md") || c.toLowerCase().includes("doctor"),
);
const isClergy =
  profile.title?.toLowerCase().includes("rev") ||
  profile.title?.toLowerCase().includes("father");
---

<div class="w-full py-2 transition-colors duration-300">
  <div class="grid grid-cols-1 items-stretch gap-6 lg:grid-cols-12 w-full">
    <!-- LEFT CARD: Portrait Image / Avatar Container -->
    <div class="lg:col-span-4 flex">
      <div
        class="relative w-full overflow-hidden rounded-3xl bg-white dark:bg-slate-900 p-3 shadow-md border border-slate-100 dark:border-slate-800 flex items-center justify-center min-h-[300px]"
      >
        {
          profile.imagePath ? (
            <img
              src={`/${profile.imagePath.replace(/^\//, "")}`}
              alt={`Photo of ${profile.name}`}
              class="h-full w-full rounded-2xl object-cover min-h-[280px]"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div class="flex h-full w-full min-h-[280px] flex-col items-center justify-center rounded-2xl bg-slate-50 dark:bg-slate-800 text-slate-400 dark:text-slate-400">
              {isMedical ? (
                <Stethoscope class="h-20 w-20" />
              ) : isClergy ? (
                <Church class="h-20 w-20" />
              ) : (
                <User class="h-20 w-20" />
              )}
              <span class="mt-3 text-xs font-medium text-slate-400 dark:text-slate-400">
                Photo Pending
              </span>
            </div>
          )
        }
      </div>
    </div>

    <!-- RIGHT CARD: Profile Details & Mini-Badge Grid -->
    <div class="lg:col-span-8 flex">
      <div
        class="flex w-full flex-col justify-between rounded-3xl bg-white dark:bg-slate-900 p-6 sm:p-8 shadow-md border border-slate-100 dark:border-slate-800"
      >
        <!-- Header & Bio -->
        <div>
          <span
            class="text-xs font-bold uppercase tracking-wider text-ribbon dark:text-rose-400"
          >
            {profile.title}
          </span>
          <h3
            class="mt-1 font-display text-2xl font-bold text-slate-900 dark:text-slate-100 sm:text-3xl"
          >
            {profile.name}
          </h3>

          {
            profile.bio && (
              <p class="mt-4 text-sm sm:text-base leading-relaxed text-slate-600 dark:text-slate-300">
                {profile.bio}
              </p>
            )
          }
        </div>

        <!-- 2x2 Mini Highlight Grid -->
        <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
          <!-- Badge 1: Role -->
          <div
            class="flex items-center gap-3 rounded-2xl border border-slate-100 dark:border-slate-800 bg-slate-50/70 dark:bg-slate-800/70 p-3.5"
          >
            <div
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-slate-200/60 dark:bg-slate-700 text-slate-700 dark:text-slate-200"
            >
              {
                isClergy ? (
                  <Church class="h-5 w-5" />
                ) : (
                  <Briefcase class="h-5 w-5" />
                )
              }
            </div>
            <div>
              <p
                class="text-[10px] font-bold uppercase tracking-wider text-slate-400 dark:text-slate-400"
              >
                Role
              </p>
              <p
                class="text-xs font-bold text-slate-800 dark:text-slate-100 line-clamp-1"
              >
                {profile.title}
              </p>
            </div>
          </div>

          <!-- Badge 2: Field -->
          <div
            class="flex items-center gap-3 rounded-2xl border border-slate-100 dark:border-slate-800 bg-slate-50/70 dark:bg-slate-800/70 p-3.5"
          >
            <div
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-slate-200/60 dark:bg-slate-700 text-slate-700 dark:text-slate-200"
            >
              {
                isMedical ? (
                  <Stethoscope class="h-5 w-5" />
                ) : (
                  <GraduationCap class="h-5 w-5" />
                )
              }
            </div>
            <div>
              <p
                class="text-[10px] font-bold uppercase tracking-wider text-slate-400 dark:text-slate-400"
              >
                Field
              </p>
              <p class="text-xs font-bold text-slate-800 dark:text-slate-100">
                {
                  isMedical
                    ? "Medical Ministry"
                    : isClergy
                      ? "Pastoral Ministry"
                      : "Community Leader"
                }
              </p>
            </div>
          </div>

          <!-- Badge 3 & 4: Credentials / Affiliation -->
          {
            profile.credentials && profile.credentials.length > 0 ? (
              profile.credentials.slice(0, 2).map((cred) => (
                <div class="flex items-center gap-3 rounded-2xl border border-slate-100 dark:border-slate-800 bg-slate-50/70 dark:bg-slate-800/70 p-3.5">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-slate-200/60 dark:bg-slate-700 text-slate-700 dark:text-slate-200">
                    <Award class="h-5 w-5" />
                  </div>
                  <div>
                    <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400 dark:text-slate-400">
                      Qualification
                    </p>
                    <p class="text-xs font-bold text-slate-800 dark:text-slate-100 line-clamp-1">
                      {cred}
                    </p>
                  </div>
                </div>
              ))
            ) : (
              <div class="flex items-center gap-3 rounded-2xl border border-slate-100 dark:border-slate-800 bg-slate-50/70 dark:bg-slate-800/70 p-3.5">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-slate-200/60 dark:bg-slate-700 text-slate-700 dark:text-slate-200">
                  <Award class="h-5 w-5" />
                </div>
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400 dark:text-slate-400">
                    Affiliation
                  </p>
                  <p class="text-xs font-bold text-slate-800 dark:text-slate-100">
                    PhilCHAN Cebu
                  </p>
                </div>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>
</div>
