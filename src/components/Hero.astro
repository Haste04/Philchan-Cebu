---
/**
 * Hero.astro
 * Above-the-fold section. Kept lightweight for optimal LCP performance.
 */
import { testingCenter } from "../data/landingData";
import { ArrowRight, ShieldCheck, Heart } from "@lucide/astro";
---

<section
  id="hero"
  class="relative overflow-hidden bg-cream/30 dark:bg-slate-950 transition-colors duration-300"
>
  <div
    class="section-container grid gap-12 py-20 sm:py-28 lg:grid-cols-2 lg:items-center"
  >
    <!-- Left Column: Primary Pitch & CTAs -->
    <div>
      <div
        class="mb-4 inline-flex items-center gap-2 rounded-full bg-deep-teal/10 dark:bg-emerald-500/15 border dark:border-emerald-500/30 px-4 py-1.5 text-xs font-semibold text-deep-teal dark:text-emerald-300 sm:text-sm"
      >
        <Heart
          class="h-4 w-4 text-ribbon fill-ribbon dark:text-rose-400 dark:fill-rose-400"
        />
        <span>Philippine Catholic HIV/AIDS Network Inc. — Cebu Chapter</span>
      </div>

      <h1
        class="font-display text-4xl font-bold tracking-tight text-charcoal dark:text-slate-50 sm:text-5xl lg:text-6xl"
      >
        Compassionate care, <span class="text-ribbon dark:text-rose-400"
          >rooted in faith.</span
        >
      </h1>

      <p
        class="mt-6 max-w-lg text-lg leading-relaxed text-charcoal/80 dark:text-slate-300"
      >
        PhilCHAN Cebu walks with every person affected by HIV/AIDS — offering
        free, confidential testing and pastoral support guided by Catholic
        social teaching and human dignity.
      </p>

      <!-- Trust Badges & CTAs -->
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a href="#testing" class="btn-primary inline-flex items-center gap-2">
          <span>Get Free & Confidential Testing</span>
          <ArrowRight class="h-4 w-4" />
        </a>
        <a
          href="#about"
          class="btn-secondary dark:border-slate-700 dark:bg-slate-800/80 dark:text-slate-200 dark:hover:bg-slate-800 dark:hover:border-slate-600"
        >
          Learn About Our Mission
        </a>
      </div>

      <!-- Quick Trust Indicator -->
      <div
        class="mt-6 flex items-center gap-2 text-xs font-medium text-charcoal/60 dark:text-emerald-400"
      >
        <ShieldCheck class="h-4 w-4 text-deep-teal dark:text-emerald-400" />
        <span>100% Confidential • Faith-Sensitive • Walk-ins Welcome</span>
      </div>
    </div>

    <!-- Right Column: Partner & Diocesan Alignment Card -->
    <div
      class="rounded-2xl border border-mist dark:border-slate-800 bg-white/80 dark:bg-slate-900/90 p-8 shadow-card dark:shadow-2xl backdrop-blur-sm transition-colors duration-300"
    >
      <p
        class="mb-6 text-center text-xs font-semibold uppercase tracking-wider text-charcoal/60 dark:text-slate-400"
      >
        In partnership with
      </p>

      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
        {
          Array.from({ length: 6 }).map((_, i) => (
            <div
              class="flex h-16 items-center justify-center rounded-lg border border-mist/50 dark:border-slate-800 bg-mist/30 dark:bg-slate-800/50 text-xs font-medium text-charcoal/40 dark:text-slate-400"
              aria-hidden="true"
            >
              Logo {i + 1}
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div class="divider-ribbon"></div>
</section>
