---
import {
  Heart,
  ArrowRight,
  ShieldCheck,
  PhoneCall,
  Sparkles,
} from "@lucide/astro";
import { Image } from "astro:assets";

// Dynamically import all images in the Hero Pics folder
const heroImageFiles = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/Hero Pics/Hero Pic *.jpg",
  { eager: true },
);

// Sort them numerically (1 to 10) based on file name
const heroImages = Object.entries(heroImageFiles)
  .sort(([pathA], [pathB]) => {
    const numA = parseInt(pathA.match(/\d+/)?.[0] || "0", 10);
    const numB = parseInt(pathB.match(/\d+/)?.[0] || "0", 10);
    return numA - numB;
  })
  .map(([_, module]) => module.default);
---

<section
  id="hero"
  class="relative overflow-hidden bg-health-white pt-32 pb-20 lg:pt-40 lg:pb-32"
>
  {/* Abstract Soft Gradient Background */}
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <div
      class="absolute -top-1/4 -right-1/4 w-[800px] h-[800px] rounded-full bg-health-green-pale/50 blur-[100px] opacity-70 mix-blend-multiply"
    >
    </div>
    <div
      class="absolute -bottom-1/4 -left-1/4 w-[600px] h-[600px] rounded-full bg-health-red/5 blur-[100px] opacity-70 mix-blend-multiply"
    >
    </div>
  </div>

  <div class="mx-auto max-w-content px-6 relative z-10">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      {/* Text Content */}
      <div class="lg:col-span-6 lg:pr-8 xl:pr-12 reveal-left">
        <div
          class="mb-6 inline-flex items-center gap-2 rounded-full bg-health-white border border-health-green/10 px-4 py-2 text-xs font-bold tracking-wide uppercase text-health-green shadow-sm"
        >
          <Sparkles class="h-4 w-4 text-health-red" />
          Modern Community Clinic
        </div>

        <h1
          class="font-display text-5xl font-bold tracking-tight text-health-text sm:text-6xl lg:text-7xl leading-[1.1]"
        >
          Compassionate care, <span class="text-health-red block mt-2"
            >rooted in faith.</span
          >
        </h1>

        <p class="mt-8 text-xl leading-relaxed text-health-text/70 max-w-lg">
          PhilCHAN Cebu provides free, confidential HIV testing, pastoral
          support, and medical care in a dignified and welcoming environment.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 items-center">
          <a
            href="#location"
            class="btn-primary w-full sm:w-auto text-lg py-4 px-8"
          >
            Find Testing Center
            <ArrowRight
              class="h-5 w-5 ml-1 transition-transform group-hover:translate-x-1"
            />
          </a>
          <a
            href="tel:+639669109662"
            class="btn-secondary w-full sm:w-auto text-lg py-4 px-8 bg-transparent"
          >
            <PhoneCall class="h-5 w-5 mr-1" />
            Call Hotline
          </a>
        </div>

        <div
          class="mt-12 flex flex-wrap items-center gap-8 text-sm font-semibold text-health-text/60"
        >
          <div class="flex items-center gap-3">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-full bg-health-green-pale"
            >
              <ShieldCheck class="h-5 w-5 text-health-green" />
            </div>
            100% Confidential
          </div>
          <div class="flex items-center gap-3">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-full bg-health-red/10"
            >
              <Heart class="h-5 w-5 text-health-red" />
            </div>
            Free Testing
          </div>
        </div>
      </div>

      {/* Rotating Hero Image Container */}
      <div class="lg:col-span-6 relative reveal-right delay-200">
        <div
          id="hero-slideshow"
          class="relative w-full h-[550px] lg:h-[700px] rounded-[3rem] overflow-hidden shadow-2xl border-4 border-health-white bg-slate-100"
        >
          {
            heroImages.map((img, index) => (
              <Image
                src={img}
                alt={`PhilCHAN Cebu Community Scene ${index + 1}`}
                class={`hero-slide absolute inset-0 w-full h-full object-cover object-center transition-opacity duration-1000 ease-in-out ${
                  index === 0 ? "opacity-100 z-10" : "opacity-0 z-0"
                }`}
                loading={index === 0 ? "eager" : "lazy"}
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0">
    <div class="divider-ribbon"></div>
  </div>

  <style>
    @keyframes float {
      0%,
      100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-15px);
      }
    }
  </style>

  <script>
    function setupSlideshow() {
      const slides = document.querySelectorAll<HTMLElement>(".hero-slide");
      if (slides.length <= 1) return;

      let currentIndex = 0;

      setInterval(() => {
        // Fade out current slide
        slides[currentIndex].classList.remove("opacity-100", "z-10");
        slides[currentIndex].classList.add("opacity-0", "z-0");

        // Advance index
        currentIndex = (currentIndex + 1) % slides.length;

        // Fade in next slide
        slides[currentIndex].classList.remove("opacity-0", "z-0");
        slides[currentIndex].classList.add("opacity-100", "z-10");
      }, 15000); // 15 seconds
    }

    // Initialize on page load and support Astro View Transitions
    setupSlideshow();
    document.addEventListener("astro:after-swap", setupSlideshow);
  </script>
</section>
