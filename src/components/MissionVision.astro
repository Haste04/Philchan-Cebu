---
/**
 * MissionVision.astro
 * Features two modern overlapping cards highlighting the organization's core tenets.
 */
import { Compass, Eye, Heart } from "@lucide/astro";
---

<section
  id="mission-vision"
  class="relative bg-gradient-to-b from-health-white to-health-bg py-24 sm:py-32 overflow-hidden"
>
  <div class="mx-auto max-w-content px-6 relative z-10">
    <div class="mb-16 text-center max-w-3xl mx-auto reveal">
      <div
        class="inline-flex items-center gap-2 rounded-full bg-health-white border border-health-green/10 px-5 py-2 text-sm font-bold tracking-wide uppercase text-health-green shadow-sm"
      >
        <Compass class="h-4 w-4" />
        Our Purpose
      </div>
      <h2
        class="mt-8 font-display text-5xl sm:text-6xl font-bold tracking-tight text-health-text"
      >
        Guided by Faith & Care
      </h2>
    </div>

    <div class="grid gap-12 lg:grid-cols-2 lg:gap-8 max-w-6xl mx-auto">
      <!-- Mission Card -->
      <div
        class="relative flex flex-col justify-between glass-card p-10 sm:p-14 lg:translate-y-8 reveal-left delay-200 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl"
      >
        <div>
          <div class="flex items-center gap-6">
            <div
              class="flex h-16 w-16 items-center justify-center rounded-3xl bg-health-red text-white shadow-md"
            >
              <Heart class="h-8 w-8" />
            </div>
            <h3
              class="font-display text-4xl font-bold text-health-text"
            >
              Mission
            </h3>
          </div>
          <p class="mt-8 text-xl leading-relaxed text-health-text/70 font-medium">
            To champion the human rights of all people living with HIV/AIDS,
            ensure comprehensive access to prevention, treatment, care, and
            support, and to break down the walls of stigma through the
            teachings and compassion of the Catholic Church.
          </p>
        </div>

        <div
          class="mt-12 flex items-center gap-3 text-sm font-bold uppercase tracking-wider text-health-text/40 border-t border-health-border/50 pt-8"
        >
          <Heart class="h-5 w-5 text-health-red" />
          Care and Compassion in Action
        </div>
      </div>

      <!-- Vision Card -->
      <div
        class="relative flex flex-col justify-between glass-card p-10 sm:p-14 lg:-translate-y-8 reveal-right delay-400 transition-all duration-500 hover:-translate-y-2 lg:hover:-translate-y-10 hover:shadow-2xl"
      >
        <div>
          <div class="flex items-center gap-6">
            <div
              class="flex h-16 w-16 items-center justify-center rounded-3xl bg-health-green text-white shadow-md"
            >
              <Eye class="h-8 w-8" />
            </div>
            <h3
              class="font-display text-4xl font-bold text-health-text"
            >
              Vision
            </h3>
          </div>
          <p class="mt-8 text-xl leading-relaxed text-health-text/70 font-medium">
            A society fully educated about HIV/AIDS where every individual,
            regardless of status, lives with dignity, experiences the unconditional
            love of the community, and has full access to the health resources
            they need to thrive.
          </p>
        </div>

        <div
          class="mt-12 flex items-center gap-3 text-sm font-bold uppercase tracking-wider text-health-text/40 border-t border-health-border/50 pt-8"
        >
          <Eye class="h-5 w-5 text-health-green" />
          A Future Built on Dignity
        </div>
      </div>
    </div>
  </div>
</section>
