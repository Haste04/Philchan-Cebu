---
/**
 * ServiceTimeline.astro
 * Vertical alternating timeline — smooth, organic entrance animations.
 */
import { Church, MapPin, Heart, Users, Handshake } from "@lucide/astro";
import { serviceMilestones, type ServiceMilestone } from "../data/serviceMilestones";

const categoryIcons: Record<string, any> = {
  founding: Church,
  chapter: MapPin,
  program: Heart,
  outreach: Users,
  partnership: Handshake,
};

const categoryLabels: Record<string, string> = {
  founding: "Founding",
  chapter: "Chapter",
  program: "Program",
  outreach: "Outreach",
  partnership: "Partnership",
};
---

<section id="medical-history" class="relative bg-health-bg py-24 sm:py-32 overflow-hidden">
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-1/4 -right-1/4 w-[600px] h-[600px] rounded-full bg-health-green-pale/40 blur-[100px] opacity-60"></div>
    <div class="absolute -bottom-1/4 -left-1/4 w-[500px] h-[500px] rounded-full bg-health-red/5 blur-[100px] opacity-60"></div>
  </div>

  <div class="mx-auto max-w-content px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20 reveal">
      <div class="inline-flex items-center gap-2 rounded-full bg-health-green/10 border border-health-green/20 px-5 py-2 text-sm font-bold tracking-wide uppercase text-health-green shadow-sm mb-8">
        <Heart class="h-4 w-4" />
        Our Journey
      </div>
      <h2 class="font-display text-5xl sm:text-6xl font-bold tracking-tight text-health-text">
        Medical & Service History
      </h2>
      <p class="mt-8 text-xl leading-relaxed text-health-text/70 font-medium max-w-2xl mx-auto">
        From our founding in 1992 to today's community health missions — a journey of faith, compassion, and service.
      </p>
    </div>

    <div id="tl-trigger" class="relative max-w-5xl mx-auto">
      <!-- Center Line -->
      <div id="tl-track" aria-hidden="true"></div>

      <div class="tl-items relative">
        {
          serviceMilestones.map((milestone, index) => {
            const Icon = categoryIcons[milestone.category] || Heart;
            const isLeft = index % 2 === 0;
            
            return (
              <div 
                class="tl-item"
                data-idx={index}
                data-side={isLeft ? "left" : "right"}
              >
                <!-- Desktop -->
                <div class={`hidden md:flex items-center w-full ${isLeft ? 'flex-row' : 'flex-row-reverse'}`}>
                  <div class="w-[calc(50%-2rem)]">
                    <div class="tl-card glass-card p-6 sm:p-8 border border-health-border/40 relative overflow-hidden group">
                      <div class="flex items-start gap-4">
                        <div class={`shrink-0 h-12 w-12 rounded-2xl flex items-center justify-center shadow-sm transition-all duration-500 group-hover:scale-110 ${milestone.category === 'founding' ? 'bg-health-red text-white' : 'bg-health-green-pale text-health-green'}`}>
                          <Icon class="h-6 w-6" />
                        </div>
                        <div class="min-w-0 flex-1">
                          <span class="px-3 py-0.5 rounded-full bg-health-green-pale/60 text-[11px] font-bold uppercase tracking-wider text-health-green">{categoryLabels[milestone.category]}</span>
                          <h3 class="mt-3 font-display text-xl font-bold text-health-text">{milestone.title}</h3>
                          <p class="mt-2 text-sm font-medium text-health-text/70 leading-relaxed">{milestone.description}</p>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="w-16 flex justify-center shrink-0">
                    <div class="tl-dot"></div>
                  </div>
                  <div class="w-[calc(50%-2rem)] flex items-center">
                    <div class={`tl-year ${isLeft ? 'ml-4' : 'mr-4 ml-auto'}`}>
                      <span class="font-display text-2xl font-bold text-health-green">{milestone.year}</span>
                    </div>
                  </div>
                </div>

                <!-- Mobile -->
                <div class="md:hidden flex items-start gap-4">
                  <div class="flex flex-col items-center shrink-0">
                    <div class="tl-dot-mb"></div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <span class="inline-block px-3 py-0.5 rounded-full bg-health-green-pale/60 text-[11px] font-bold uppercase tracking-wider text-health-green mb-2">
                      {milestone.year} &middot; {categoryLabels[milestone.category]}
                    </span>
                    <div class="tl-card glass-card p-5 border border-health-border/40 relative overflow-hidden group">
                      <div class="flex items-start gap-3">
                        <div class={`shrink-0 h-10 w-10 rounded-xl flex items-center justify-center shadow-sm ${milestone.category === 'founding' ? 'bg-health-red text-white' : 'bg-health-green-pale text-health-green'}`}>
                          <Icon class="h-5 w-5" />
                        </div>
                        <div>
                          <h3 class="font-display text-base font-bold text-health-text">{milestone.title}</h3>
                          <p class="mt-1.5 text-sm font-medium text-health-text/70 leading-relaxed">{milestone.description}</p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* =======================================
     CENTER LINE — slow, smooth draw
     ======================================= */
  #tl-track {
    display: none;
  }

  @media (min-width: 768px) {
    #tl-track {
      display: block;
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 3px;
      background: linear-gradient(to bottom, #2C5E48, #D95B5B, #2C5E48);
      transform: translateX(-50%) scaleY(0);
      transform-origin: top;
      transition: transform 1.8s cubic-bezier(0.4, 0, 0.2, 1);
      border-radius: 999px;
    }

    #tl-trigger.tl-animated #tl-track {
      transform: translateX(-50%) scaleY(1);
    }
  }

  /* =======================================
     ITEMS — smooth slide + fade
     ======================================= */
  .tl-item {
    opacity: 0;
  }

  .tl-item[data-side="left"] {
    transform: translateX(-40px);
  }

  .tl-item[data-side="right"] {
    transform: translateX(40px);
  }

  .tl-item.tl-show {
    opacity: 1 !important;
    transform: translateX(0) !important;
    transition: opacity 1s cubic-bezier(0.4, 0, 0.2, 1),
                transform 1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* =======================================
     DOT — soft pulse ring
     ======================================= */
  .tl-dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #FCFBF9;
    border: 4px solid #D95B5B;
    box-shadow: 0 0 0 4px rgba(217, 91, 91, 0.15);
    z-index: 2;
    opacity: 0;
    transform: scale(0.3);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .tl-dot.tl-dot-pulse {
    opacity: 1;
    transform: scale(1);
    animation: tlPulseSoft 1s ease-out 2;
  }

  @keyframes tlPulseSoft {
    0%   { box-shadow: 0 0 0 0 rgba(217, 91, 91, 0.4), 0 0 0 4px rgba(217, 91, 91, 0.12); }
    50%  { box-shadow: 0 0 0 12px rgba(217, 91, 91, 0), 0 0 0 4px rgba(217, 91, 91, 0.12); }
    100% { box-shadow: 0 0 0 0 rgba(217, 91, 91, 0), 0 0 0 4px rgba(217, 91, 91, 0.12); }
  }

  /* =======================================
     DOT MOBILE
     ======================================= */
  .tl-dot-mb {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #D95B5B;
    border: 3px solid #FCFBF9;
    box-shadow: 0 0 0 3px rgba(217, 91, 91, 0.2);
    margin-top: 6px;
    z-index: 2;
    position: relative;
    opacity: 0;
    transform: scale(0.3);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .tl-dot-mb.tl-dot-pulse {
    opacity: 1;
    transform: scale(1);
    animation: tlPulseSoftMb 1s ease-out 2;
  }

  @keyframes tlPulseSoftMb {
    0%   { box-shadow: 0 0 0 0 rgba(217, 91, 91, 0.4), 0 0 0 3px rgba(217, 91, 91, 0.15); }
    50%  { box-shadow: 0 0 0 10px rgba(217, 91, 91, 0), 0 0 0 3px rgba(217, 91, 91, 0.15); }
    100% { box-shadow: 0 0 0 0 rgba(217, 91, 91, 0), 0 0 0 3px rgba(217, 91, 91, 0.15); }
  }

  .tl-item:not(:last-child) .tl-dot-mb::after {
    content: '';
    position: absolute;
    top: 18px;
    left: 50%;
    width: 2px;
    height: calc(100% + 1.5rem);
    background: #D1DBD5;
    transform: translateX(-50%);
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .tl-item.tl-show .tl-dot-mb::after {
    opacity: 1;
  }

  /* =======================================
     YEAR BADGE — smooth scale in
     ======================================= */
  .tl-year {
    opacity: 0;
    transform: scale(0.7);
    transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tl-year.tl-year-show {
    opacity: 1;
    transform: scale(1);
  }

  /* =======================================
     GRADIENT BAR — smooth sweep
     ======================================= */
  .tl-card {
    position: relative;
    overflow: hidden;
  }

  .tl-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    height: 4px;
    width: 0%;
    background: linear-gradient(to right, #D95B5B, #2C5E48);
    border-radius: 4px 4px 0 0;
    transition: width 1.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tl-card.tl-bar-show::before {
    width: 100%;
  }

  /* =======================================
     REDUCED MOTION
     ======================================= */
  @media (prefers-reduced-motion: reduce) {
    .tl-item {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .tl-dot, .tl-dot-mb {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
    .tl-year {
      opacity: 1 !important;
      transform: none !important;
    }
    .tl-dot-mb::after { opacity: 1 !important; }
    .tl-card::before { width: 100% !important; }
    #tl-track { transform: translateX(-50%) scaleY(1) !important; }
  }
</style>

<script is:inline>
  (function() {
    function initTL() {
      var trigger = document.getElementById('tl-trigger');
      if (!trigger) return;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        trigger.classList.add('tl-animated');
        trigger.querySelectorAll('.tl-item').forEach(function(el) { el.classList.add('tl-show'); });
        trigger.querySelectorAll('.tl-dot, .tl-dot-mb').forEach(function(el) { el.classList.add('tl-dot-pulse'); });
        trigger.querySelectorAll('.tl-year').forEach(function(el) { el.classList.add('tl-year-show'); });
        trigger.querySelectorAll('.tl-card').forEach(function(el) { el.classList.add('tl-bar-show'); });
        return;
      }

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            trigger.classList.add('tl-animated');

            var items = trigger.querySelectorAll('.tl-item');
            for (var i = 0; i < items.length; i++) {
              (function(idx) {
                var delay = idx * 100;
                setTimeout(function() {
                  var item = items[idx];
                  item.classList.add('tl-show'); // slide in

                  var dot = item.querySelector('.tl-dot') || item.querySelector('.tl-dot-mb');
                  if (dot) {
                    setTimeout(function() { dot.classList.add('tl-dot-pulse'); }, 200);
                  }

                  var year = item.querySelector('.tl-year');
                  if (year) {
                    setTimeout(function() { year.classList.add('tl-year-show'); }, 100);
                  }

                  var card = item.querySelector('.tl-card');
                  if (card) {
                    setTimeout(function() { card.classList.add('tl-bar-show'); }, 400);
                  }
                }, delay);
              })(i);
            }
            observer.unobserve(trigger);
          }
        });
      }, { root: null, rootMargin: '0px 0px -60px 0px', threshold: 0.1 });

      observer.observe(trigger);
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initTL);
    else initTL();
    document.addEventListener('astro:after-swap', initTL);
  })();
</script>
