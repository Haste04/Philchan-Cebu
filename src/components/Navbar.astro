---
/**
 * Navbar.astro
 * Sticky navbar with light/dark mode toggle, active section underlines,
 * scroll progress bar, and responsive mobile menu.
 */
import { Image } from "astro:assets";
import { navItems } from "../data/landingData";
import { Menu, X, Heart, Sun, Moon } from "@lucide/astro";
import logoImage from "../assets/images/logos/PhilChan-Cebu Logo.jpg";
import logoImage2 from "../assets/images/logos/CBCP-ECHC Logo.png";
import logoImage3 from "../assets/images/logos/Catholic Bishop's Logo.png";
---

<header
  class="sticky top-0 z-40 border-b border-mist bg-linen/90 backdrop-blur dark:border-slate-800 dark:bg-slate-900/90 transition-colors duration-300"
>
  <nav
    class="w-full px-4 sm:px-6 lg:px-8 flex items-center justify-between py-3"
    aria-label="Primary"
  >
    <!-- Logo & Brand Name (Aligned Far Left) -->
    <a
      href="#hero"
      class="flex items-center gap-3 font-display text-lg font-semibold text-deep-teal dark:text-emerald-400"
    >
      <div class="flex items-center gap-2">
        <Image
          src={logoImage}
          alt="PhilCHAN Cebu logo"
          width={40}
          height={40}
          class="rounded-full h-9 w-9 sm:h-10 sm:w-10 object-cover"
        />
        <Image
          src={logoImage2}
          alt="CBCP logo"
          width={40}
          height={40}
          class="rounded-full h-9 w-9 sm:h-10 sm:w-10 object-cover"
        />
        <Image
          src={logoImage3}
          alt="Catholic Bishop's logo"
          width={40}
          height={40}
          class="rounded-full h-9 w-9 sm:h-10 sm:w-10 object-cover"
        />
      </div>
      <span class="hidden sm:inline whitespace-nowrap">PhilCHAN Cebu</span>
    </a>

    <!-- Desktop Nav Links -->
    <ul id="desktop-nav-menu" class="hidden items-center gap-8 md:flex">
      {
        navItems.map((item, index) => (
          <li>
            <a
              href={item.href}
              class={`nav-link font-body text-sm font-semibold py-1 transition-all duration-200 hover:text-deep-teal dark:hover:text-emerald-400 ${
                index === 0
                  ? "active border-b-2 border-ribbon text-ribbon"
                  : "text-charcoal dark:text-slate-300"
              }`}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Controls & Actions -->
    <div class="flex items-center gap-4">
      <!-- LIGHT / DARK MODE TOGGLE BUTTON -->
      <button
        id="theme-toggle"
        type="button"
        class="rounded-lg p-2 text-charcoal hover:bg-mist/50 dark:text-slate-300 dark:hover:bg-slate-800 focus:outline-none transition-colors"
        aria-label="Toggle dark mode"
      >
        <Sun class="hidden h-5 w-5 dark:block text-amber-400" />
        <Moon class="h-5 w-5 dark:hidden text-slate-700" />
      </button>

      <!-- CTA Button (Desktop) -->
      <a href="#testing" class="hidden md:inline-flex btn-primary text-sm">
        Get Tested Free
      </a>

      <!-- Mobile Menu Toggle -->
      <details id="mobile-menu-details" class="group relative md:hidden">
        <summary
          class="list-none cursor-pointer rounded-md p-2 text-charcoal hover:bg-mist/50 dark:text-slate-300 dark:hover:bg-slate-800 [&::-webkit-details-marker]:hidden"
          aria-label="Toggle Navigation Menu"
        >
          <Menu class="h-6 w-6 group-open:hidden" />
          <X class="hidden h-6 w-6 group-open:block" />
        </summary>

        <!-- Mobile Dropdown -->
        <ul
          class="absolute right-0 top-12 w-56 rounded-xl border border-mist bg-linen p-3 shadow-card dark:border-slate-800 dark:bg-slate-900"
        >
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="mobile-nav-link block rounded-md px-3 py-2 text-sm font-medium text-charcoal hover:bg-mist dark:text-slate-200 dark:hover:bg-slate-800 transition-colors"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
          <li class="mt-1 border-t border-mist dark:border-slate-800 pt-2">
            <a
              href="#testing"
              class="block rounded-md px-3 py-2 text-sm font-semibold text-ribbon hover:bg-mist/50 dark:hover:bg-slate-800 transition-colors"
            >
              Get Tested Free
            </a>
          </li>
        </ul>
      </details>
    </div>
  </nav>

  <!-- SCROLL PROGRESS BAR -->
  <div class="h-1 w-full bg-mist/40 dark:bg-slate-800 overflow-hidden">
    <div
      id="scroll-progress-bar"
      class="h-full w-0 bg-ribbon transition-all duration-150 ease-out"
    >
    </div>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // 1. Light/Dark Mode Toggle Script
    const themeToggleBtn = document.getElementById("theme-toggle");

    themeToggleBtn?.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });

    // 2. Scroll Progress Bar
    const progressBar = document.getElementById("scroll-progress-bar");
    const updateProgressBar = () => {
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const scrollHeight =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const progress = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;

      if (progressBar) {
        progressBar.style.width = `${Math.min(100, Math.max(0, progress))}%`;
      }
    };

    window.addEventListener("scroll", updateProgressBar, { passive: true });
    updateProgressBar();

    // 3. Desktop Active Link Underline
    const navLinks = document.querySelectorAll<HTMLAnchorElement>(".nav-link");
    navLinks.forEach((link) => {
      link.addEventListener("click", function () {
        navLinks.forEach((l) => {
          l.classList.remove(
            "active",
            "border-b-2",
            "border-ribbon",
            "text-ribbon",
          );
          l.classList.add("text-charcoal", "dark:text-slate-300");
        });

        this.classList.add(
          "active",
          "border-b-2",
          "border-ribbon",
          "text-ribbon",
        );
        this.classList.remove("text-charcoal", "dark:text-slate-300");
      });
    });

    // 4. Auto-close mobile dropdown
    const mobileNavLinks =
      document.querySelectorAll<HTMLAnchorElement>(".mobile-nav-link");
    const mobileDetails = document.querySelector<HTMLDetailsElement>(
      "#mobile-menu-details",
    );
    mobileNavLinks.forEach((link) => {
      link.addEventListener("click", () => {
        mobileDetails?.removeAttribute("open");
      });
    });
  });
</script>
