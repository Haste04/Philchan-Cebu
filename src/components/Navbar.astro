---
/**
 * Navbar.astro
 * Sticky floating circle/pill navbar with glassmorphism.
 */
import { Image } from "astro:assets";
import { navItems } from "../data/landingData";
import { Menu, X } from "@lucide/astro";
import logoImage from "../assets/images/logos/PhilChan-Cebu Logo.jpg";
import logoImage2 from "../assets/images/logos/CBCP-ECHC Logo.png";
import logoImage3 from "../assets/images/logos/Catholic Bishop's Logo.png";
---

<header
  id="main-nav"
  class="sticky top-4 z-50 w-full px-4 sm:px-6 transition-all duration-300"
>
  <nav
    class="mx-auto flex max-w-content items-center justify-between px-3 py-2 sm:px-4 rounded-full bg-health-white/95 backdrop-blur-xl border border-health-border/40 shadow-card"
    aria-label="Primary"
  >
    <!-- Logo & Brand Name -->
    <a
      href="/"
      class="flex items-center gap-3 font-display text-xl font-bold text-health-green hover:opacity-80 transition-opacity pl-2"
    >
      <div class="flex items-center gap-1 bg-health-white p-1 rounded-full shadow-sm border border-health-border/30">
        <Image
          src={logoImage}
          alt="PhilCHAN Cebu logo"
          width={32}
          height={32}
          class="rounded-full h-8 w-8 object-cover"
        />
        <Image
          src={logoImage2}
          alt="CBCP logo"
          width={32}
          height={32}
          class="rounded-full h-8 w-8 object-cover"
        />
        <Image
          src={logoImage3}
          alt="Catholic Bishop's logo"
          width={32}
          height={32}
          class="rounded-full h-8 w-8 object-cover"
        />
      </div>
      <span class="hidden lg:inline tracking-tight text-[22px]">PhilCHAN Cebu</span>
    </a>

    <!-- Desktop Nav Links -->
    <ul id="desktop-nav-menu" class="hidden items-center gap-1 md:flex">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="nav-link relative block px-5 py-2.5 font-body text-[15px] font-bold text-health-text/80 transition-all duration-200 hover:text-health-red rounded-full hover:bg-health-red/5"
            >
              {item.label}
              <span class="absolute bottom-1 left-1/2 h-1 w-1 -translate-x-1/2 rounded-full bg-health-red opacity-0 transition-opacity duration-300 nav-indicator"></span>
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Controls & Actions -->
    <div class="flex items-center gap-2 sm:gap-3">
      <!-- CTA Button (Desktop) -->
      <a href="/#location" class="hidden md:inline-flex btn-primary text-sm px-6 py-2.5 shadow-sm hover:shadow-md transition-shadow">
        Get Tested Free
      </a>

      <!-- Mobile Menu Toggle -->
      <details id="mobile-menu-details" class="group relative md:hidden">
        <summary
          class="list-none cursor-pointer rounded-full p-2.5 text-health-green bg-health-green/5 hover:bg-health-green/10 [&::-webkit-details-marker]:hidden transition-colors"
          aria-label="Toggle Navigation Menu"
        >
          <Menu class="h-6 w-6 group-open:hidden" />
          <X class="hidden h-6 w-6 group-open:block" />
        </summary>

        <!-- Mobile Dropdown -->
        <ul
          class="absolute right-0 top-16 w-[280px] rounded-3xl border border-health-border/50 bg-health-white/95 backdrop-blur-xl p-4 shadow-card origin-top-right transition-all transform opacity-0 scale-95 pointer-events-none group-open:opacity-100 group-open:scale-100 group-open:pointer-events-auto"
        >
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="mobile-nav-link block rounded-2xl px-5 py-3.5 text-base font-bold text-health-text hover:bg-health-green-pale hover:text-health-green transition-colors"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
          <li class="mt-3 border-t border-health-border/40 pt-3">
            <a
              href="/#location"
              class="block w-full rounded-2xl px-5 py-3.5 text-base font-bold text-white bg-health-red hover:bg-health-red-dark transition-colors text-center shadow-soft"
            >
              Get Tested Free
            </a>
          </li>
        </ul>
      </details>
    </div>
  </nav>
</header>

<script>
  function initNavbar() {
    // Active Link Highlight
    const currentPath = window.location.pathname;
    const navLinks = document.querySelectorAll<HTMLAnchorElement>(".nav-link");
    
    navLinks.forEach((link) => {
      const linkPath = new URL(link.href).pathname;
      const indicator = link.querySelector('.nav-indicator');
      
      if (linkPath === currentPath || (linkPath === '/' && currentPath === '')) {
        link.classList.add("text-health-red", "bg-health-red/10");
        link.classList.remove("text-health-text/80");
        indicator?.classList.remove('opacity-0');
      } else {
        link.classList.remove("text-health-red", "bg-health-red/10");
        link.classList.add("text-health-text/80");
        indicator?.classList.add('opacity-0');
      }
    });

    // Auto-close mobile dropdown
    const mobileNavLinks = document.querySelectorAll<HTMLAnchorElement>(".mobile-nav-link");
    const mobileDetails = document.querySelector<HTMLDetailsElement>("#mobile-menu-details");
    
    mobileNavLinks.forEach((link) => {
      link.addEventListener("click", () => {
        mobileDetails?.removeAttribute("open");
      });
    });
  }

  document.addEventListener("DOMContentLoaded", initNavbar);
  document.addEventListener("astro:after-swap", initNavbar);
</script>
