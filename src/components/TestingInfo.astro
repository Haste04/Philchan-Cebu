---
import { Heart, Activity, Church, Users, ShieldCheck } from "@lucide/astro";

const services = [
  {
    title: "Confidential HIV Testing",
    description: "Rapid, safe, and completely free testing conducted with the highest standards of privacy and clinical accuracy.",
    icon: Activity,
    color: "health-red"
  },
  {
    title: "Pastoral Care & Counseling",
    description: "Faith-based emotional and spiritual support tailored to your journey, provided in a welcoming, non-judgmental space.",
    icon: Church,
    color: "health-green"
  },
  {
    title: "Medical Navigation",
    description: "Professional guidance through healthcare systems, including assistance with treatment access and ongoing care coordination.",
    icon: ShieldCheck,
    color: "health-green"
  },
  {
    title: "Community Education",
    description: "Outreach programs designed to break down stigma, raise awareness, and foster a supportive, informed society.",
    icon: Users,
    color: "health-green"
  }
];
---

<section id="services" class="relative z-10 bg-health-white py-24 sm:py-32 overflow-hidden">
  {/* Abstract Soft Gradient Background */}
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 right-0 w-[800px] h-[800px] rounded-full bg-health-green-pale/40 blur-[100px] mix-blend-multiply opacity-50 -translate-y-1/2 translate-x-1/4"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] rounded-full bg-health-red/5 blur-[100px] mix-blend-multiply opacity-50 translate-y-1/4 -translate-x-1/4"></div>
  </div>

  <div class="mx-auto max-w-content px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20 reveal">
      <div
        class="inline-flex items-center gap-2 rounded-full bg-health-red/10 border border-health-red/20 px-5 py-2 text-sm font-bold tracking-wide uppercase text-health-red shadow-sm mb-8"
      >
        <Heart class="h-4 w-4" />
        Our Services
      </div>
      <h2
        class="font-display text-5xl sm:text-6xl font-bold tracking-tight text-health-text"
      >
        Comprehensive Care & Support
      </h2>
      <p class="mt-8 text-xl leading-relaxed text-health-text/70 font-medium">
        We offer a holistic approach to health, combining professional medical services with deep compassion and faith-based support.
      </p>
    </div>

    {/* Medium 2x2 Grid with beautifully proportioned cards */}
    <div class="grid md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto">
      {
        services.map((service, index) => {
          const Icon = service.icon;
          const isRed = service.color === "health-red";
          
          return (
            <div class={`glass-card p-8 sm:p-10 lg:p-12 flex flex-col items-center text-center transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl border border-health-border/40 group reveal delay-${(index % 2 + 1) * 200}`}>
              <div class={`h-16 w-16 rounded-2xl flex items-center justify-center mb-6 shadow-sm group-hover:scale-110 transition-transform duration-500 ${isRed ? 'bg-health-red text-white' : 'bg-health-green-pale text-health-green group-hover:bg-health-green group-hover:text-white'}`}>
                <Icon class="h-8 w-8" />
              </div>
              <h3 class={`text-2xl font-display font-bold mb-4 ${isRed ? 'text-health-red' : 'text-health-green'}`}>
                {service.title}
              </h3>
              <p class="text-health-text/70 leading-relaxed font-medium text-base">
                {service.description}
              </p>
            </div>
          );
        })
      }
    </div>

    <div class="mt-16 text-center reveal delay-500">
      <a href="#location" class="btn-primary py-3.5 px-10 text-base shadow-lg">
        Visit Our Center
      </a>
    </div>
  </div>
</section>
