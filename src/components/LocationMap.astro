---
import { testingCenter } from "../data/landingData";
import { Clock, MapPin, Phone, Mail, Navigation } from "@lucide/astro";
---

<section id="location" class="section-container relative z-10 bg-health-bg py-16 sm:py-20 overflow-hidden">
  <div class="mb-10 text-center max-w-3xl mx-auto reveal">
    <h2
      class="text-4xl sm:text-5xl font-display font-bold text-health-text"
    >
      Find Us
    </h2>
    <p class="mt-4 text-lg text-health-text/70 font-medium">
      Our clinic is located at Mt. Zion Center in Talamban.
    </p>
  </div>

  <div class="grid gap-8 lg:grid-cols-12 lg:gap-8 items-stretch max-w-7xl mx-auto">
    {/* Contact Information Card */}
    <div class="lg:col-span-5 relative z-20 reveal-left delay-200">
      <div class="glass-card h-full p-8 border border-health-white/60 shadow-xl flex flex-col justify-between">
        <div>
          <h3
            class="font-display text-2xl font-bold text-health-green"
          >
            {testingCenter.name}
          </h3>

          <div class="mt-8 space-y-5">
            <div class="flex items-start gap-4 group">
              <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-health-green-pale transition-transform group-hover:scale-110 group-hover:bg-health-green group-hover:text-white text-health-green shadow-sm">
                <MapPin class="h-5 w-5 transition-colors" />
              </div>
              <div>
                <p class="font-bold text-health-text text-base mb-0.5">Address</p>
                {
                  testingCenter.addressLines.map((line) => (
                    <p class="text-health-text/70 font-medium text-sm">{line}</p>
                  ))
                }
              </div>
            </div>

            <div class="flex items-start gap-4 group">
              <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-health-green-pale transition-transform group-hover:scale-110 group-hover:bg-health-green group-hover:text-white text-health-green shadow-sm">
                <Clock class="h-5 w-5 transition-colors" />
              </div>
              <div class="w-full">
                <p class="font-bold text-health-text text-base mb-1">Clinic Hours</p>
                <ul class="space-y-1.5 text-health-text/70 font-medium text-sm">
                  {
                    testingCenter.hours.map((hour) => (
                      <li class="flex justify-between items-center gap-4 border-b border-health-border/30 pb-1.5 last:border-0 last:pb-0">
                        <span>{hour.day}</span>
                        <span class="font-bold text-health-green">{hour.time}</span>
                      </li>
                    ))
                  }
                </ul>
              </div>
            </div>

            <div class="flex items-start gap-4 group">
              <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-health-red/10 transition-transform group-hover:scale-110 group-hover:bg-health-red group-hover:text-white text-health-red shadow-sm">
                <Phone class="h-5 w-5 transition-colors" />
              </div>
              <div>
                <p class="font-bold text-health-text text-base mb-0.5">Hotline</p>
                {
                  testingCenter.contactNumbers.map((contact) => (
                    <div class="mt-0.5">
                      <a
                        href={contact.href}
                        class="text-health-red hover:text-health-red-dark font-bold text-base transition-colors"
                      >
                        {contact.number}
                      </a>
                    </div>
                  ))
                }
              </div>
            </div>

            <div class="flex items-start gap-4 group">
              <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-health-green-pale transition-transform group-hover:scale-110 group-hover:bg-health-green group-hover:text-white text-health-green shadow-sm">
                <Mail class="h-5 w-5 transition-colors" />
              </div>
              <div>
                <p class="font-bold text-health-text text-base mb-0.5">Email</p>
                <a
                  href={`mailto:${testingCenter.email}`}
                  class="text-health-green hover:text-health-green-light font-bold text-sm transition-colors"
                >
                  {testingCenter.email}
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-8 pt-6 border-t border-health-border/40">
          <a
            href={testingCenter.mapDirectionsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary w-full justify-center rounded-xl py-3 text-base shadow-sm hover:shadow-md"
          >
            <Navigation class="mr-2 h-5 w-5" />
            Get Directions
          </a>
        </div>
      </div>
    </div>

    {/* Map Container */}
    <div class="lg:col-span-7 relative h-[400px] lg:h-auto min-h-[400px] reveal-right delay-400">
      <div
        class="h-full w-full overflow-hidden rounded-[2.5rem] shadow-xl border-[6px] border-health-white/80 bg-health-white/50 backdrop-blur-md relative z-10"
      >
        <iframe
          src={testingCenter.mapEmbedSrc}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Google Maps Location for PhilCHAN Cebu"
          class="h-full w-full object-cover grayscale-[10%] contrast-110 hover:grayscale-0 transition-all duration-700"
        ></iframe>
      </div>
      
      {/* Decorative Blur behind map */}
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full max-w-lg max-h-lg bg-health-green-pale/80 blur-[80px] rounded-full z-0 mix-blend-multiply"></div>
    </div>
  </div>
</section>
