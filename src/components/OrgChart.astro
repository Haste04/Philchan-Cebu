---
/**
 * OrgChart.astro
 * Matches the official PhilCHAN Cebu Organizational Chart hierarchy and pill node layout.
 */
import { User, ArrowDown } from "@lucide/astro";

interface OrgNode {
  name: string;
  title: string;
  imagePath?: string;
}

// 1. Top Tier: President
const president: OrgNode = {
  name: "Rev. Fr. Rodolfo V. Cancino MI",
  title: "PRESIDENT, PhilCHAN",
};

// 2. Second Tier: Coordinator / Head
const coordinator: OrgNode = {
  name: "Greta U. Canoy, FPOG, MD",
  title: "Coordinator, PhilCHAN Cebu / Head, PhilCHAN Community Center",
};

// 3. Admin & Finance Branch (Left)
const adminBranch: OrgNode[] = [
  {
    name: "Ron Revin B. Miranda, RN, USRN, MSN",
    title: "COMMUNITY CENTER ADMINISTRATIVE AND FINANCE OFFICER",
  },
  {
    name: "Nelle B. Prado",
    title: "COMMUNITY MOBILIZING OFFICER",
  },
];

// 4. Corporate & Board Branch (Middle)
const boardBranch: OrgNode[] = [
  {
    name: "Carmela Matheu",
    title: "Corporate Secretary, PhilCHAN",
  },
  {
    name: "Violeta Hoyohoy",
    title: "Board Member, PhilCHAN",
  },
];

// 5. Members Grid (Right - 2 columns x 4 rows)
const members: OrgNode[] = [
  { name: "Brenette L. Abrenica", title: "MEMBER" },
  { name: "Ma. Ligaya Suico", title: "MEMBER" },
  { name: "Maria Taping", title: "MEMBER" },
  { name: "Ma. Elena B. Yumang", title: "MEMBER" },
  { name: "Norieza Marte", title: "MEMBER" },
  { name: "Joydeleen M. Revilla, RGC", title: "MEMBER" },
  { name: "Joyce Cabije, DOH -7", title: "MEMBER" },
  { name: "Arnie Montes, DOH - 7", title: "MEMBER" },
];
---

<section
  id="org-chart"
  class="bg-slate-50/50 dark:bg-slate-950 py-16 lg:py-24 border-t border-slate-200/60 dark:border-slate-800/80 transition-colors duration-300"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center">
      <h2
        class="font-display text-2xl font-bold tracking-tight text-slate-900 dark:text-slate-100 sm:text-3xl lg:text-4xl"
      >
        PHILIPPINE CATHOLIC HIV/AIDS NETWORK INC.
      </h2>
      <p
        class="mt-2 text-lg font-semibold text-emerald-800 dark:text-emerald-400"
      >
        Organizational Chart
      </p>
      <p class="text-sm font-medium text-slate-500 dark:text-slate-400">
        Cebu City Chapter
      </p>
    </div>

    <!-- Tree Hierarchy Container -->
    <div class="mt-12 flex flex-col items-center">
      <!-- LEVEL 1: PRESIDENT -->
      <div class="relative z-10">
        <div
          class="flex items-center gap-3.5 rounded-full bg-emerald-100/90 dark:bg-slate-900/90 py-2.5 px-6 border border-emerald-300 dark:border-emerald-500/40 shadow-sm max-w-md"
        >
          <div
            class="h-14 w-14 shrink-0 overflow-hidden rounded-full border-2 border-emerald-500 dark:border-emerald-400 bg-white dark:bg-slate-800 shadow-inner flex items-center justify-center"
          >
            {
              president.imagePath ? (
                <img
                  src={`/${president.imagePath}`}
                  alt={president.name}
                  class="h-full w-full object-cover"
                />
              ) : (
                <User class="h-8 w-8 text-emerald-700 dark:text-emerald-400" />
              )
            }
          </div>
          <div>
            <h3 class="text-sm font-bold text-slate-900 dark:text-slate-100">
              {president.name}
            </h3>
            <p
              class="text-xs font-semibold text-emerald-800 dark:text-emerald-400"
            >
              {president.title}
            </p>
          </div>
        </div>
      </div>

      <!-- Arrow 1 -->
      <div
        class="my-2 flex flex-col items-center text-slate-400 dark:text-slate-500"
      >
        <ArrowDown class="h-6 w-6 stroke-[2.5]" />
      </div>

      <!-- LEVEL 2: COORDINATOR / HEAD -->
      <div class="relative z-10">
        <div
          class="flex items-center gap-3.5 rounded-full bg-emerald-100/90 dark:bg-slate-900/90 py-2.5 px-6 border border-emerald-300 dark:border-emerald-500/40 shadow-sm max-w-lg"
        >
          <div
            class="h-14 w-14 shrink-0 overflow-hidden rounded-full border-2 border-emerald-500 dark:border-emerald-400 bg-white dark:bg-slate-800 shadow-inner flex items-center justify-center"
          >
            {
              coordinator.imagePath ? (
                <img
                  src={`/${coordinator.imagePath}`}
                  alt={coordinator.name}
                  class="h-full w-full object-cover"
                />
              ) : (
                <User class="h-8 w-8 text-emerald-700 dark:text-emerald-400" />
              )
            }
          </div>
          <div>
            <h3 class="text-sm font-bold text-slate-900 dark:text-slate-100">
              {coordinator.name}
            </h3>
            <p
              class="text-xs font-semibold text-emerald-800 dark:text-emerald-400"
            >
              {coordinator.title}
            </p>
          </div>
        </div>
      </div>

      <!-- Branch Connectors (Desktop Horizontal Line) -->
      <div class="relative mt-6 w-full max-w-5xl">
        <div
          class="hidden lg:block absolute left-1/2 -top-6 h-6 w-0.5 bg-slate-300 dark:bg-slate-700 -translate-x-1/2"
        >
        </div>
        <div
          class="hidden lg:block w-full border-t-2 border-dashed border-slate-300 dark:border-slate-700"
        >
        </div>
      </div>

      <!-- LEVEL 3: THREE BRANCHES -->
      <div
        class="mt-8 grid grid-cols-1 gap-10 lg:grid-cols-12 w-full max-w-6xl items-start"
      >
        <!-- BRANCH 1: Admin & Mobilizing Officers (Left Column) -->
        <div class="lg:col-span-4 flex flex-col items-center gap-6">
          {
            adminBranch.map((node, index) => (
              <>
                <div class="flex w-full items-center gap-3 rounded-full bg-emerald-100/90 dark:bg-slate-900/90 py-2.5 px-5 border border-emerald-300 dark:border-emerald-500/40 shadow-sm">
                  <div class="h-12 w-12 shrink-0 overflow-hidden rounded-full border-2 border-emerald-500 dark:border-emerald-400 bg-white dark:bg-slate-800 flex items-center justify-center">
                    <User class="h-7 w-7 text-emerald-700 dark:text-emerald-400" />
                  </div>
                  <div>
                    <h4 class="text-xs font-bold text-slate-900 dark:text-slate-100">
                      {node.name}
                    </h4>
                    <p class="text-[10px] font-bold text-emerald-800 dark:text-emerald-400 leading-tight uppercase mt-0.5">
                      {node.title}
                    </p>
                  </div>
                </div>

                {index < adminBranch.length - 1 && (
                  <ArrowDown class="h-5 w-5 text-slate-400 dark:text-slate-500 -my-2" />
                )}
              </>
            ))
          }
        </div>

        <!-- BRANCH 2: Corporate Secretary & Board (Middle Column) -->
        <div class="lg:col-span-3 flex flex-col items-center gap-6">
          {
            boardBranch.map((node, index) => (
              <>
                <div class="flex w-full items-center gap-3 rounded-full bg-emerald-100/90 dark:bg-slate-900/90 py-2.5 px-5 border border-emerald-300 dark:border-emerald-500/40 shadow-sm">
                  <div class="h-12 w-12 shrink-0 overflow-hidden rounded-full border-2 border-emerald-500 dark:border-emerald-400 bg-white dark:bg-slate-800 flex items-center justify-center">
                    <User class="h-7 w-7 text-emerald-700 dark:text-emerald-400" />
                  </div>
                  <div>
                    <h4 class="text-xs font-bold text-slate-900 dark:text-slate-100">
                      {node.name}
                    </h4>
                    <p class="text-[10px] font-bold text-emerald-800 dark:text-emerald-400 leading-tight uppercase mt-0.5">
                      {node.title}
                    </p>
                  </div>
                </div>

                {index < boardBranch.length - 1 && (
                  <ArrowDown class="h-5 w-5 text-slate-400 dark:text-slate-500 -my-2" />
                )}
              </>
            ))
          }
        </div>

        <!-- BRANCH 3: Members Grid (Right 2-Column Grid) -->
        <div class="lg:col-span-5 grid grid-cols-1 sm:grid-cols-2 gap-3">
          {
            members.map((member) => (
              <div class="flex items-center gap-2.5 rounded-full bg-emerald-100/90 dark:bg-slate-900/90 py-2 px-3.5 border border-emerald-300 dark:border-emerald-500/40 shadow-sm">
                <div class="h-10 w-10 shrink-0 overflow-hidden rounded-full border-2 border-emerald-500 dark:border-emerald-400 bg-white dark:bg-slate-800 flex items-center justify-center">
                  <User class="h-6 w-6 text-emerald-700 dark:text-emerald-400" />
                </div>
                <div class="min-w-0">
                  <h4 class="text-xs font-bold text-slate-900 dark:text-slate-100 truncate">
                    {member.name}
                  </h4>
                  <p class="text-[10px] font-bold text-emerald-800 dark:text-emerald-400">
                    {member.title}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
