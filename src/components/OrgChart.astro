---
/**
 * OrgChart.astro
 * Matches the official PhilCHAN Cebu Organizational Chart hierarchy and pill node layout, with modern polished styling.
 */
import { User, ArrowDown } from "@lucide/astro";

interface OrgNode {
  name: string;
  title: string;
  imagePath?: string;
}

// 1. Top Tier: President
const president: OrgNode = {
  name: "Rev. Fr. Rodolfo V. Cancino MI",
  title: "PRESIDENT, PhilCHAN",
};

// 2. Second Tier: Coordinator / Head
const coordinator: OrgNode = {
  name: "Greta U. Canoy, FPOG, MD",
  title: "Coordinator, PhilCHAN Cebu / Head, PhilCHAN Community Center",
};

// 3. Admin & Finance Branch (Left)
const adminBranch: OrgNode[] = [
  {
    name: "Ron Revin B. Miranda, RN, USRN, MSN",
    title: "COMMUNITY CENTER ADMINISTRATIVE AND FINANCE OFFICER",
  },
  {
    name: "Nelle B. Prado",
    title: "COMMUNITY MOBILIZING OFFICER",
  },
];

// 4. Corporate & Board Branch (Middle)
const boardBranch: OrgNode[] = [
  {
    name: "Carmela Matheu",
    title: "Corporate Secretary, PhilCHAN",
  },
  {
    name: "Violeta Hoyohoy",
    title: "Board Member, PhilCHAN",
  },
];

// 5. Members Grid (Right - 2 columns x 4 rows)
const members: OrgNode[] = [
  { name: "Brenette L. Abrenica", title: "MEMBER" },
  { name: "Ma. Ligaya Suico", title: "MEMBER" },
  { name: "Maria Taping", title: "MEMBER" },
  { name: "Ma. Elena B. Yumang", title: "MEMBER" },
  { name: "Norieza Marte", title: "MEMBER" },
  { name: "Joydeleen M. Revilla, RGC", title: "MEMBER" },
  { name: "Joyce Cabije, DOH -7", title: "MEMBER" },
  { name: "Arnie Montes, DOH - 7", title: "MEMBER" },
];
---

<section
  id="org-chart"
  class="bg-health-bg py-20 lg:py-32 relative overflow-hidden z-10 transition-colors duration-300"
>
  <div class="mx-auto max-w-7xl px-6 lg:px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center reveal">
      <h2
        class="font-display text-4xl sm:text-5xl font-bold tracking-tight text-health-green"
      >
        Organizational Chart
      </h2>
      <p
        class="mt-4 text-xl font-medium text-health-text/70"
      >
        PHILIPPINE CATHOLIC HIV/AIDS NETWORK INC. &mdash; Cebu City Chapter
      </p>
    </div>

    <!-- Tree Hierarchy Container -->
    <div class="mt-16 flex flex-col items-center">
      <!-- LEVEL 1: PRESIDENT -->
      <div class="relative z-10 reveal delay-100">
        <div
          class="flex items-center gap-4 rounded-[2rem] bg-health-white p-3 pr-8 border border-health-border shadow-soft max-w-md hover:shadow-card transition-shadow"
        >
          <div
            class="h-16 w-16 shrink-0 overflow-hidden rounded-3xl bg-health-green-pale flex items-center justify-center"
          >
            {
              president.imagePath ? (
                <img
                  src={`/${president.imagePath}`}
                  alt={president.name}
                  class="h-full w-full object-cover"
                />
              ) : (
                <User class="h-8 w-8 text-health-green" />
              )
            }
          </div>
          <div>
            <h3 class="text-base font-bold text-health-text">
              {president.name}
            </h3>
            <p
              class="text-xs font-bold text-health-green uppercase tracking-wider mt-1"
            >
              {president.title}
            </p>
          </div>
        </div>
      </div>

      <!-- Arrow 1 -->
      <div
        class="my-4 flex flex-col items-center text-health-border reveal delay-200"
      >
        <ArrowDown class="h-6 w-6 stroke-[3]" />
      </div>

      <!-- LEVEL 2: COORDINATOR / HEAD -->
      <div class="relative z-10 reveal delay-300">
        <div
          class="flex items-center gap-4 rounded-[2rem] bg-health-white p-3 pr-8 border border-health-border shadow-soft max-w-lg hover:shadow-card transition-shadow"
        >
          <div
            class="h-16 w-16 shrink-0 overflow-hidden rounded-3xl bg-health-green-pale flex items-center justify-center"
          >
            {
              coordinator.imagePath ? (
                <img
                  src={`/${coordinator.imagePath}`}
                  alt={coordinator.name}
                  class="h-full w-full object-cover"
                />
              ) : (
                <User class="h-8 w-8 text-health-green" />
              )
            }
          </div>
          <div>
            <h3 class="text-base font-bold text-health-text">
              {coordinator.name}
            </h3>
            <p
              class="text-xs font-bold text-health-green uppercase tracking-wider mt-1"
            >
              {coordinator.title}
            </p>
          </div>
        </div>
      </div>

      <!-- Branch Connectors (Desktop Horizontal Line) -->
      <div class="relative mt-8 w-full max-w-5xl reveal delay-400">
        <div
          class="hidden lg:block absolute left-1/2 -top-8 h-8 w-0.5 bg-health-border -translate-x-1/2"
        >
        </div>
        <div
          class="hidden lg:block w-full border-t-2 border-dashed border-health-border"
        >
        </div>
      </div>

      <!-- LEVEL 3: THREE BRANCHES -->
      <div
        class="mt-10 grid grid-cols-1 gap-12 lg:grid-cols-12 w-full max-w-6xl items-start"
      >
        <!-- BRANCH 1: Admin & Mobilizing Officers (Left Column) -->
        <div class="lg:col-span-4 flex flex-col items-center gap-6 reveal-left delay-500">
          {
            adminBranch.map((node, index) => (
              <>
                <div class="flex w-full items-center gap-4 rounded-[2rem] bg-health-white p-2.5 pr-6 border border-health-border shadow-soft hover:shadow-md transition-shadow">
                  <div class="h-12 w-12 shrink-0 overflow-hidden rounded-2xl bg-health-green-pale flex items-center justify-center">
                    <User class="h-6 w-6 text-health-green" />
                  </div>
                  <div>
                    <h4 class="text-sm font-bold text-health-text">
                      {node.name}
                    </h4>
                    <p class="text-[10px] font-bold text-health-green leading-tight uppercase mt-1 tracking-wider">
                      {node.title}
                    </p>
                  </div>
                </div>

                {index < adminBranch.length - 1 && (
                  <ArrowDown class="h-5 w-5 text-health-border -my-2" />
                )}
              </>
            ))
          }
        </div>

        <!-- BRANCH 2: Corporate Secretary & Board (Middle Column) -->
        <div class="lg:col-span-3 flex flex-col items-center gap-6 reveal delay-500">
          {
            boardBranch.map((node, index) => (
              <>
                <div class="flex w-full items-center gap-4 rounded-[2rem] bg-health-white p-2.5 pr-6 border border-health-border shadow-soft hover:shadow-md transition-shadow">
                  <div class="h-12 w-12 shrink-0 overflow-hidden rounded-2xl bg-health-green-pale flex items-center justify-center">
                    <User class="h-6 w-6 text-health-green" />
                  </div>
                  <div>
                    <h4 class="text-sm font-bold text-health-text">
                      {node.name}
                    </h4>
                    <p class="text-[10px] font-bold text-health-green leading-tight uppercase mt-1 tracking-wider">
                      {node.title}
                    </p>
                  </div>
                </div>

                {index < boardBranch.length - 1 && (
                  <ArrowDown class="h-5 w-5 text-health-border -my-2" />
                )}
              </>
            ))
          }
        </div>

        <!-- BRANCH 3: Members Grid (Right 2-Column Grid) -->
        <div class="lg:col-span-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
          {
            members.map((member, index) => (
              <div class={`flex items-center gap-3 rounded-[2rem] bg-health-white p-2 pr-4 border border-health-border shadow-sm hover:shadow-md transition-shadow reveal-right delay-${(index % 4 + 2) * 100}`}>
                <div class="h-10 w-10 shrink-0 overflow-hidden rounded-2xl bg-health-green-pale flex items-center justify-center">
                  <User class="h-5 w-5 text-health-green" />
                </div>
                <div class="min-w-0">
                  <h4 class="text-sm font-bold text-health-text truncate">
                    {member.name}
                  </h4>
                  <p class="text-[10px] font-bold text-health-green uppercase tracking-wider mt-0.5">
                    {member.title}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
